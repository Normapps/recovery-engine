# Copy this file to .env.local and fill in your values.
# Never commit .env.local — it is gitignored.

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Get your key at: platform.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── Supabase ────────────────────────────────────────────────────────────────
# Find these at: app.supabase.com → your project → Settings → API
#
#   Project URL  →  SUPABASE_URL / NEXT_PUBLIC_SUPABASE_URL
#   anon/public  →  SUPABASE_ANON_KEY / NEXT_PUBLIC_SUPABASE_ANON_KEY
#
# Use NEXT_PUBLIC_ for browser/client components.
# Use the unprefixed version for server-side API routes.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
